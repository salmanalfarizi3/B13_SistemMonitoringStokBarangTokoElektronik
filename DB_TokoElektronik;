--  STORED PROCEDURE — sp_InsertSupplier

IF EXISTS (SELECT 1 FROM sys.procedures WHERE name = 'sp_InsertSupplier')
    DROP PROCEDURE sp_InsertSupplier;
GO

CREATE PROCEDURE sp_InsertSupplier
    @ID_Supplier   CHAR(5),
    @Nama_Supplier VARCHAR(100),
    @Alamat        VARCHAR(200),
    @No_Telp       VARCHAR(15),
    @RowsAffected  INT OUTPUT
AS
BEGIN
    SET NOCOUNT ON;

    IF EXISTS (SELECT 1 FROM Supplier WHERE ID_Supplier = @ID_Supplier)
    BEGIN
        SET @RowsAffected = -1;
        RETURN;
    END

    INSERT INTO Supplier (ID_Supplier, Nama_Supplier, Alamat, No_Telp)
    VALUES (@ID_Supplier, @Nama_Supplier, @Alamat, @No_Telp);

    SET @RowsAffected = @@ROWCOUNT;
END
GO
PRINT '? SP sp_InsertSupplier berhasil dibuat';


--STORED PROCEDURE — sp_UpdateSupplier

IF EXISTS (SELECT 1 FROM sys.procedures WHERE name = 'sp_UpdateSupplier')
    DROP PROCEDURE sp_UpdateSupplier;
GO

CREATE PROCEDURE sp_UpdateSupplier
    @ID_Supplier   CHAR(5),
    @Nama_Supplier VARCHAR(100),
    @Alamat        VARCHAR(200),
    @No_Telp       VARCHAR(15),
    @RowsAffected  INT OUTPUT
AS
BEGIN
    SET NOCOUNT ON;

    UPDATE Supplier
    SET Nama_Supplier = @Nama_Supplier,
        Alamat        = @Alamat,
        No_Telp       = @No_Telp
    WHERE ID_Supplier = @ID_Supplier;

    SET @RowsAffected = @@ROWCOUNT;
END
GO
PRINT '? SP sp_UpdateSupplier berhasil dibuat';

--STORED PROCEDURE — sp_DeleteSupplier

IF EXISTS (SELECT 1 FROM sys.procedures WHERE name = 'sp_DeleteSupplier')
    DROP PROCEDURE sp_DeleteSupplier;
GO

CREATE PROCEDURE sp_DeleteSupplier
    @ID_Supplier  CHAR(5),
    @RowsAffected INT OUTPUT
AS
BEGIN
    SET NOCOUNT ON;

    -- Cek  Supplier masih digunakan di tabel Barang
    IF EXISTS (SELECT 1 FROM Barang WHERE ID_Supplier = @ID_Supplier)
    BEGIN
        SET @RowsAffected = -2; 
        RETURN;
    END

    DELETE FROM Supplier WHERE ID_Supplier = @ID_Supplier;
    SET @RowsAffected = @@ROWCOUNT;
END
GO
PRINT '? SP sp_DeleteSupplier berhasil dibuat';


