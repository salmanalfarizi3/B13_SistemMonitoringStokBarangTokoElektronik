    SELECT 1 FROM INFORMATION_SCHEMA.COLUMNS 
    WHERE TABLE_NAME = 'Riwayat_Masuk' AND COLUMN_NAME = 'ID_Supplier'
)
BEGIN
    ALTER TABLE Riwayat_Masuk ADD ID_Supplier CHAR(5) NULL;
    PRINT '? Kolom ID_Supplier ditambahkan ke Riwayat_Masuk';
END
ELSE
    PRINT '? Kolom ID_Supplier sudah ada di Riwayat_Masuk';
GO


--  VIEW — vw_Barang

IF EXISTS (SELECT 1 FROM sys.views WHERE name = 'vw_Barang')
    DROP VIEW vw_Barang;
GO

CREATE VIEW vw_Barang AS
    SELECT
        b.ID_Barang      AS [ID Barang],
        b.Nama_Barang    AS [Nama Barang],
        b.Kategori,
        b.Harga,
        b.Stok,
        ISNULL(s.Nama_Supplier, '-') AS [Nama Supplier],
        CASE
            WHEN b.Stok = 0  THEN 'Habis'
            WHEN b.Stok < 5  THEN 'Menipis'
            WHEN b.Stok < 20 THEN 'Normal'
            ELSE                  'Aman'
        END AS [Status Stok]
    FROM Barang b
    LEFT JOIN Supplier s ON b.ID_Supplier = s.ID_Supplier;
GO
PRINT '? VIEW vw_Barang berhasil dibuat';

-- ============================================================
-- LANGKAH 3: VIEW — vw_RiwayatMasuk
-- DIPERBAIKI: Digunakan oleh FormRiwayat.cs dan Form1.cs
--             (TampilRiwayat — sebelumnya masih raw SQL JOIN)
-- ============================================================
IF EXISTS (SELECT 1 FROM sys.views WHERE name = 'vw_RiwayatMasuk')
    DROP VIEW vw_RiwayatMasuk;
GO

CREATE VIEW vw_RiwayatMasuk AS
    SELECT
        r.ID_Riwayat                                    AS [ID Riwayat],
        r.ID_Barang                                     AS [ID Barang],
        r.Nama_Barang                                   AS [Nama Barang],
        r.Jumlah_Masuk                                  AS [Jumlah Masuk],
        r.Keterangan,
        ISNULL(s.Nama_Supplier, '-')                    AS [Nama Supplier],
        CONVERT(VARCHAR, r.Tanggal_Masuk, 105) + ' ' +
        CONVERT(VARCHAR, r.Tanggal_Masuk, 108)          AS [Tanggal dan Jam]
    FROM Riwayat_Masuk r
    LEFT JOIN Supplier s ON r.ID_Supplier = s.ID_Supplier;
GO
PRINT '? VIEW vw_RiwayatMasuk berhasil dibuat';


-- STORED PROCEDURE — sp_Login

IF EXISTS (SELECT 1 FROM sys.procedures WHERE name = 'sp_Login')
    DROP PROCEDURE sp_Login;
GO

CREATE PROCEDURE sp_Login
    @Username  VARCHAR(50),
    @Password  VARCHAR(50),
    @IsValid   BIT OUTPUT,
    @Role      VARCHAR(20) OUTPUT
AS
BEGIN
    SET NOCOUNT ON;

    SELECT @IsValid = 1, @Role = Role
    FROM Users
    WHERE Username = @Username AND Password = @Password;

    IF @IsValid IS NULL
    BEGIN
        SET @IsValid = 0;
        SET @Role    = '';
    END
END
GO
PRINT '? SP sp_Login berhasil dibuat';


--STORED PROCEDURE — sp_InsertBarang

IF EXISTS (SELECT 1 FROM sys.procedures WHERE name = 'sp_InsertBarang')
    DROP PROCEDURE sp_InsertBarang;
GO

CREATE PROCEDURE sp_InsertBarang
    @ID_Barang    VARCHAR(50),
    @Nama_Barang  VARCHAR(100),
    @Kategori     VARCHAR(50),
    @Harga        DECIMAL(18,2),
    @Stok         INT,
    @ID_Supplier  CHAR(5),
    @RowsAffected INT OUTPUT
AS
BEGIN
    SET NOCOUNT ON;

    -- Cek duplikat ID
    IF EXISTS (SELECT 1 FROM Barang WHERE ID_Barang = @ID_Barang)
    BEGIN
        SET @RowsAffected = -1;
        RETURN;
    END

    -- Insert ke tabel Barang
    INSERT INTO Barang (ID_Barang, Nama_Barang, Kategori, Harga, Stok, ID_Supplier)
    VALUES (@ID_Barang, @Nama_Barang, @Kategori, @Harga, @Stok,
            CASE WHEN @ID_Supplier = '' THEN NULL ELSE @ID_Supplier END);

    -- Catat ke Riwayat_Masuk (otomatis saat barang baru ditambah)
    INSERT INTO Riwayat_Masuk (ID_Barang, Nama_Barang, Jumlah_Masuk, Tanggal_Masuk, Keterangan, ID_Supplier)
    VALUES (@ID_Barang, @Nama_Barang, @Stok, GETDATE(), 'Barang Baru',
            CASE WHEN @ID_Supplier = '' THEN NULL ELSE @ID_Supplier END);

    SET @RowsAffected = @@ROWCOUNT;
END
GO
PRINT '? SP sp_InsertBarang berhasil dibuat';


--STORED PROCEDURE — sp_UpdateBarang

IF EXISTS (SELECT 1 FROM sys.procedures WHERE name = 'sp_UpdateBarang')
    DROP PROCEDURE sp_UpdateBarang;
GO

CREATE PROCEDURE sp_UpdateBarang
    @ID_Barang    VARCHAR(50),
    @Nama_Barang  VARCHAR(100),
    @Kategori     VARCHAR(50),
    @Harga        DECIMAL(18,2),
    @Stok         INT,
    @ID_Supplier  CHAR(5),
    @RowsAffected INT OUTPUT
AS
BEGIN
    SET NOCOUNT ON;

    UPDATE Barang
    SET Nama_Barang  = @Nama_Barang,
        Kategori     = @Kategori,
        Harga        = @Harga,
        Stok         = @Stok,
        ID_Supplier  = CASE WHEN @ID_Supplier = '' THEN NULL ELSE @ID_Supplier END
    WHERE ID_Barang = @ID_Barang;

    -- Catat perubahan ke Riwayat_Masuk
    INSERT INTO Riwayat_Masuk (ID_Barang, Nama_Barang, Jumlah_Masuk, Tanggal_Masuk, Keterangan, ID_Supplier)
    VALUES (@ID_Barang, @Nama_Barang, @Stok, GETDATE(), 'Update Stok/Data',
            CASE WHEN @ID_Supplier = '' THEN NULL ELSE @ID_Supplier END);

    SET @RowsAffected = @@ROWCOUNT;
END
GO
PRINT '? SP sp_UpdateBarang berhasil dibuat';


