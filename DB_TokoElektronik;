-- LANGKAH 8: STORED PROCEDURE — sp_SearchBarang  ? BARU

IF EXISTS (SELECT 1 FROM sys.procedures WHERE name = 'sp_SearchBarang')
    DROP PROCEDURE sp_SearchBarang;
GO

CREATE PROCEDURE sp_SearchBarang
    @Keyword VARCHAR(100)
AS
BEGIN
    SET NOCOUNT ON;


    SELECT * FROM vw_Barang
    WHERE [Nama Barang] LIKE '%' + @Keyword + '%'
       OR [ID Barang]   LIKE '%' + @Keyword + '%'
       OR Kategori      LIKE '%' + @Keyword + '%'
    ORDER BY [ID Barang];
END
GO
PRINT '? SP sp_SearchBarang berhasil dibuat';


